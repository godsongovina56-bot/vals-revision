<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>MATH101 Quiz</title>
<style>
  body { font-family: Arial, sans-serif; background: #f4f7fb; padding: 20px; margin: 0; }
.quiz-container { max-width: 750px; margin: 40px auto; background: white; padding: 30px; border-radius: 10px; box-shadow: 0 4px 15px rgba(0,0,0,0.1); }
  h1 { color: #1a73e8; text-align: center; margin-bottom: 10px; }
.counter { text-align: center; color: #666; margin-bottom: 20px; font-size: 14px; }
.question { font-size: 18px; margin-bottom: 15px; font-weight: bold; line-height: 1.5; }
.options button { display: block; width: 100%; padding: 12px 15px; margin: 8px 0; border: 2px solid #1a73e8; background: white; border-radius: 6px; cursor: pointer; text-align: left; font-size: 16px; transition: 0.2s; }
.options button:hover:not(:disabled) { background: #e8f0fe; }
.options button:disabled { cursor: not-allowed; opacity: 0.9; }
.explanation { margin-top: 10px; padding: 12px; background: #e8f0fe; border-left: 4px solid #1a73e8; border-radius: 5px; display: none; }
  #nextBtn { padding: 12px 25px; background: #1a73e8; color: white; border: none; border-radius: 6px; cursor: pointer; font-size: 16px; margin-top: 15px; font-weight: bold; }
  #nextBtn:hover { background: #1557b0; }
  #score { text-align: center; font-size: 24px; margin-top: 20px; font-weight: bold; color: #1a73e8; }
</style>
</head>
<body>
<div class="quiz-container">
  <h1>MATH101 Quiz</h1>
  <div class="counter" id="counter"></div>
  <div id="quiz">
    <div class="question" id="question"></div>
    <div class="options" id="options"></div>
    <div class="explanation" id="explanation"></div>
    <button id="nextBtn" style="display:none;">Next Question</button>
  </div>
  <div id="score"></div>
</div>

